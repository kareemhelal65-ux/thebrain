{
  "category": "crm",
  "description": "Full customer relationship management — contacts, deals, pipelines, lead scoring, campaign management, churn prediction, and customer intelligence.",
  "tools": [
    { "name": "get_contact", "description": "Retrieve detailed contact information", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "contact_id": { "type": "string" }, "email": { "type": "string" } }, "required": [] } },
    { "name": "create_contact", "description": "Create a new contact or lead", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "first_name": { "type": "string" }, "last_name": { "type": "string" }, "email": { "type": "string" }, "phone": { "type": "string" }, "company": { "type": "string" }, "title": { "type": "string" }, "tags": { "type": "array", "items": { "type": "string" } }, "source": { "type": "string", "enum": ["website", "referral", "cold_outreach", "event", "social_media", "advertisement", "other"] }, "custom_fields": { "type": "object" } }, "required": ["email"] } },
    { "name": "update_contact", "description": "Update an existing contact's details, tags, or lifecycle stage", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "contact_id": { "type": "string" }, "updates": { "type": "object" }, "lifecycle_stage": { "type": "string", "enum": ["subscriber", "lead", "mql", "sql", "opportunity", "customer", "evangelist"] } }, "required": ["contact_id"] } },
    { "name": "search_contacts", "description": "Search contacts by name, email, company, tags, or custom fields", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "query": { "type": "string" }, "filters": { "type": "object" }, "lifecycle_stage": { "type": "string" }, "limit": { "type": "integer", "default": 25 } }, "required": ["query"] } },
    { "name": "update_deal", "description": "Update a deal/opportunity stage, value, or details", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "deal_id": { "type": "string" }, "stage": { "type": "string" }, "value": { "type": "number" }, "close_date": { "type": "string" }, "probability": { "type": "number" }, "notes": { "type": "string" } }, "required": ["deal_id"] } },
    { "name": "create_deal", "description": "Create a new deal/opportunity in the sales pipeline", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "name": { "type": "string" }, "contact_id": { "type": "string" }, "value": { "type": "number" }, "currency": { "type": "string", "default": "EGP" }, "pipeline": { "type": "string" }, "stage": { "type": "string" }, "close_date": { "type": "string" }, "owner": { "type": "string" }, "probability": { "type": "number" } }, "required": ["name", "value"] } },
    { "name": "list_deals", "description": "List deals with stage, owner, value, and date filters", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "stage": { "type": "string" }, "owner": { "type": "string" }, "min_value": { "type": "number" }, "pipeline": { "type": "string" }, "limit": { "type": "integer", "default": 25 } }, "required": [] } },
    { "name": "log_activity", "description": "Log a call, email, meeting, or note against a contact or deal", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "contact_id": { "type": "string" }, "deal_id": { "type": "string" }, "type": { "type": "string", "enum": ["call", "email", "meeting", "note", "task", "sms"] }, "subject": { "type": "string" }, "body": { "type": "string" }, "outcome": { "type": "string", "enum": ["connected", "left_voicemail", "no_answer", "busy", "interested", "not_interested"] }, "duration_minutes": { "type": "integer" }, "timestamp": { "type": "string" } }, "required": ["type", "subject"] } },
    { "name": "lead_scoring", "description": "Calculate or retrieve lead scores based on demographic fit, behavioral signals, and engagement history", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["score_contact", "get_top_leads", "configure_model", "score_all"] }, "contact_id": { "type": "string" }, "scoring_criteria": { "type": "object", "properties": { "demographic_weight": { "type": "number", "default": 0.3 }, "behavioral_weight": { "type": "number", "default": 0.5 }, "engagement_weight": { "type": "number", "default": 0.2 } } }, "min_score": { "type": "number" }, "limit": { "type": "integer", "default": 25 } }, "required": ["action"] } },
    { "name": "pipeline_forecast", "description": "Forecast pipeline revenue by stage, probability-weighted expected value, and win-rate trends", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "pipeline": { "type": "string" }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "include_weighted": { "type": "boolean", "default": true }, "group_by": { "type": "string", "enum": ["stage", "owner", "month", "product"] } }, "required": [] } },
    { "name": "churn_prediction", "description": "Predict which customers are at risk of churning based on engagement decline, support tickets, usage patterns, and payment history", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "time_horizon_days": { "type": "integer", "default": 90 }, "risk_threshold": { "type": "number", "default": 0.7, "description": "Minimum probability to flag (0-1)" }, "include_reasons": { "type": "boolean", "default": true }, "segment": { "type": "string" } }, "required": [] } },
    { "name": "campaign_create", "description": "Create a sales or marketing campaign with target audience, messaging, and scheduling", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "string", "enum": ["email_sequence", "call_campaign", "nurture", "re_engagement", "onboarding", "upsell"] }, "audience_filter": { "type": "object", "description": "Filter criteria for target contacts" }, "messages": { "type": "array", "items": { "type": "object", "properties": { "day_offset": { "type": "integer" }, "subject": { "type": "string" }, "body": { "type": "string" }, "channel": { "type": "string", "enum": ["email", "sms", "call"] } } } }, "start_date": { "type": "string" } }, "required": ["name", "type"] } },
    { "name": "campaign_analytics", "description": "Get performance analytics for a campaign — open rates, click rates, conversions, and ROI", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "campaign_id": { "type": "string" }, "metrics": { "type": "array", "items": { "type": "string", "enum": ["open_rate", "click_rate", "reply_rate", "conversion_rate", "revenue_attributed", "cost_per_acquisition", "roi"] } } }, "required": ["campaign_id"] } },
    { "name": "territory_management", "description": "Assign, view, or rebalance sales territories based on geography, industry, or account size", "category": "crm", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["view_territories", "assign_territory", "rebalance", "analyze_coverage"] }, "rep_id": { "type": "string" }, "territory": { "type": "object", "properties": { "name": { "type": "string" }, "criteria": { "type": "object" } } } }, "required": ["action"] } },
    { "name": "customer_health_score", "description": "Calculate an aggregate health score for a customer account based on product usage, support interactions, payment timeliness, and NPS", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "customer_id": { "type": "string" }, "components": { "type": "array", "items": { "type": "string", "enum": ["usage", "support_tickets", "payment_history", "nps", "engagement", "contract_status"] }, "default": ["usage", "support_tickets", "payment_history", "nps"] } }, "required": ["customer_id"] } },
    { "name": "nps_survey", "description": "Create, send, or analyze Net Promoter Score surveys", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create_survey", "send_to_segment", "get_results", "analyze_trends"] }, "segment_filter": { "type": "object" }, "survey_id": { "type": "string" }, "period": { "type": "string" } }, "required": ["action"] } },
    { "name": "sales_leaderboard", "description": "Generate a sales performance leaderboard with metrics by rep, team, or region", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "period": { "type": "string" }, "group_by": { "type": "string", "enum": ["rep", "team", "region"] }, "metrics": { "type": "array", "items": { "type": "string", "enum": ["revenue_closed", "deals_won", "deals_lost", "pipeline_created", "calls_made", "emails_sent", "meetings_held", "conversion_rate"] } }, "limit": { "type": "integer", "default": 20 } }, "required": ["period"] } },
    { "name": "automated_followup", "description": "Configure or trigger automated follow-up sequences based on deal stage, inactivity, or custom triggers", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create_sequence", "trigger_for_contact", "pause_sequence", "get_status"] }, "contact_id": { "type": "string" }, "trigger": { "type": "string", "enum": ["deal_stage_change", "days_inactive", "email_opened", "form_submitted", "custom"] }, "sequence_steps": { "type": "array", "items": { "type": "object", "properties": { "delay_days": { "type": "integer" }, "action": { "type": "string" }, "template": { "type": "string" } } } } }, "required": ["action"] } },
    { "name": "duplicate_detection", "description": "Scan for and merge duplicate contacts, companies, or deals in the CRM", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "entity_type": { "type": "string", "enum": ["contacts", "companies", "deals"] }, "action": { "type": "string", "enum": ["scan", "preview_merge", "merge", "ignore"] }, "match_fields": { "type": "array", "items": { "type": "string" }, "default": ["email", "phone", "name"] }, "duplicate_ids": { "type": "array", "items": { "type": "string" } } }, "required": ["entity_type", "action"] } },
    { "name": "revenue_attribution", "description": "Attribute revenue to marketing channels, campaigns, or touchpoints using first-touch, last-touch, linear, or time-decay models", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "model": { "type": "string", "enum": ["first_touch", "last_touch", "linear", "time_decay", "position_based", "data_driven"] }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "group_by": { "type": "string", "enum": ["channel", "campaign", "source", "medium"] } }, "required": ["model"] } },
    { "name": "lead_intelligence", "description": "Enrich lead data with industry trends, company size, and recent news for better targeting", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "company_domain": { "type": "string" }, "contact_email": { "type": "string" } }, "required": ["company_domain"] } },
    { "name": "pipeline_audit", "description": "Analyze the sales funnel to identify bottlenecks, stagnation, and leakages", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "pipeline_id": { "type": "string" }, "timeframe": { "type": "string", "default": "last_90_days" } }, "required": [] } },
    { "name": "proposal_generator", "description": "Draft custom sales proposals or quotes based on deal and contact data", "category": "crm", "required_role": "Employee", "parameters": { "type": "object", "properties": { "deal_id": { "type": "string" }, "template_id": { "type": "string" }, "custom_terms": { "type": "string" } }, "required": ["deal_id"] } },
    { "name": "external_sync", "description": "Bidirectional synchronization with external CRM platforms like Salesforce or HubSpot", "category": "crm", "required_role": "Admin", "parameters": { "type": "object", "properties": { "platform": { "type": "string", "enum": ["salesforce", "hubspot", "pipedrive", "zoho"] }, "direction": { "type": "string", "enum": ["push", "pull", "sync"] }, "record_ids": { "type": "array", "items": { "type": "string" } } }, "required": ["platform", "direction"] } },
    { "name": "investor_pipeline_mgmt", "description": "Track VC/Angel outreach, meeting notes, and follow-up status for fundraising rounds", "category": "crm", "required_role": "Admin", "parameters": { "type": "object", "properties": { "investor_name": { "type": "string" }, "fund_name": { "type": "string" }, "stage": { "type": "string", "enum": ["target", "contacted", "first_meeting", "due_diligence", "term_sheet", "closed", "passed"] }, "last_interaction": { "type": "string" }, "next_step": { "type": "string" } }, "required": ["investor_name"] } },
    { "name": "founder_cold_outreach", "description": "Generate and manage personalized cold outreach sequences specifically for founder-led sales or partnerships", "category": "crm", "required_role": "Manager", "parameters": { "type": "object", "properties": { "target_type": { "type": "string", "enum": ["customer", "partner", "investor", "advisor"] }, "tone": { "type": "string", "default": "personal_direct" }, "num_steps": { "type": "integer", "default": 3 } }, "required": ["target_type"] } }
  ]
}
