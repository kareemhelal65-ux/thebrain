{
  "category": "project-management",
  "description": "Full project lifecycle management — tasks, sprints, resources, risk, milestones, dependencies, capacity planning, and retrospectives.",
  "tools": [
    { "name": "create_task", "description": "Create a new task or issue in a project", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" }, "project_id": { "type": "string" }, "assignee": { "type": "string" }, "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] }, "due_date": { "type": "string" }, "labels": { "type": "array", "items": { "type": "string" } }, "estimated_hours": { "type": "number" }, "parent_task_id": { "type": "string" }, "task_type": { "type": "string", "enum": ["task", "bug", "feature", "story", "epic", "subtask"] } }, "required": ["title", "project_id"] } },
    { "name": "update_task", "description": "Update a task's status, assignee, priority, or other fields", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "task_id": { "type": "string" }, "status": { "type": "string" }, "assignee": { "type": "string" }, "priority": { "type": "string" }, "due_date": { "type": "string" }, "comment": { "type": "string" } }, "required": ["task_id"] } },
    { "name": "list_tasks", "description": "List tasks with filters for project, status, assignee, and priority", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" }, "status": { "type": "string" }, "assignee": { "type": "string" }, "priority": { "type": "string" }, "overdue_only": { "type": "boolean", "default": false }, "limit": { "type": "integer", "default": 25 } }, "required": [] } },
    { "name": "get_project", "description": "Retrieve project details including status, members, and progress", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" } }, "required": ["project_id"] } },
    { "name": "assign_task", "description": "Assign or reassign a task to a team member", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "task_id": { "type": "string" }, "assignee": { "type": "string" }, "notify": { "type": "boolean", "default": true } }, "required": ["task_id", "assignee"] } },
    { "name": "log_time", "description": "Log time worked on a task", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "task_id": { "type": "string" }, "hours": { "type": "number" }, "description": { "type": "string" }, "date": { "type": "string" }, "billable": { "type": "boolean", "default": true } }, "required": ["task_id", "hours"] } },
    { "name": "create_project", "description": "Create a new project with scope, timeline, methodology, and team", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "name": { "type": "string" }, "description": { "type": "string" }, "start_date": { "type": "string" }, "end_date": { "type": "string" }, "methodology": { "type": "string", "enum": ["agile", "waterfall", "kanban", "hybrid"] }, "team_members": { "type": "array", "items": { "type": "string" } }, "budget": { "type": "number" } }, "required": ["name"] } },
    { "name": "sprint_management", "description": "Create, start, end, or review sprints for agile projects", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create", "start", "end", "get_current", "list_sprints", "add_tasks"] }, "project_id": { "type": "string" }, "sprint_name": { "type": "string" }, "start_date": { "type": "string" }, "end_date": { "type": "string" }, "goal": { "type": "string" }, "task_ids": { "type": "array", "items": { "type": "string" } } }, "required": ["action", "project_id"] } },
    { "name": "burndown_chart", "description": "Generate burndown/burnup chart data for a sprint or project", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" }, "sprint_id": { "type": "string" }, "chart_type": { "type": "string", "enum": ["burndown", "burnup", "cumulative_flow"], "default": "burndown" }, "unit": { "type": "string", "enum": ["story_points", "tasks", "hours"], "default": "story_points" } }, "required": ["project_id"] } },
    { "name": "velocity_tracking", "description": "Track team velocity across sprints with trend lines and capacity predictions", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" }, "num_sprints": { "type": "integer", "default": 6 }, "include_forecast": { "type": "boolean", "default": true } }, "required": ["project_id"] } },
    { "name": "risk_assessment", "description": "Identify, assess, and track project risks with probability/impact scoring and mitigation plans", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["identify", "assess", "add_mitigation", "get_risk_matrix", "update_status"] }, "project_id": { "type": "string" }, "risk": { "type": "object", "properties": { "title": { "type": "string" }, "probability": { "type": "string", "enum": ["low", "medium", "high", "very_high"] }, "impact": { "type": "string", "enum": ["minor", "moderate", "major", "critical"] }, "category": { "type": "string", "enum": ["technical", "schedule", "budget", "resource", "scope", "external"] }, "mitigation": { "type": "string" } } } }, "required": ["action", "project_id"] } },
    { "name": "resource_allocation", "description": "View and manage resource allocation — workload balancing, availability, and utilization rates", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["view_allocation", "assign_resource", "check_availability", "utilization_report", "rebalance"] }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "team_member": { "type": "string" }, "project_id": { "type": "string" } }, "required": ["action"] } },
    { "name": "dependency_map", "description": "Map and manage task dependencies — identify critical path, blockers, and dependency chains", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["add_dependency", "remove_dependency", "view_chain", "critical_path", "find_blockers"] }, "project_id": { "type": "string" }, "task_id": { "type": "string" }, "depends_on": { "type": "string" }, "dependency_type": { "type": "string", "enum": ["finish_to_start", "start_to_start", "finish_to_finish"], "default": "finish_to_start" } }, "required": ["action", "project_id"] } },
    { "name": "milestone_tracking", "description": "Create and track project milestones with deliverables and completion status", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create", "update", "list", "mark_complete", "get_timeline"] }, "project_id": { "type": "string" }, "milestone": { "type": "object", "properties": { "name": { "type": "string" }, "target_date": { "type": "string" }, "status": { "type": "string", "enum": ["upcoming", "in_progress", "at_risk", "completed", "missed"] } } } }, "required": ["action", "project_id"] } },
    { "name": "capacity_planning", "description": "Forecast team capacity for future periods based on headcount, vacation, and velocity", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "team_id": { "type": "string" }, "periods": { "type": "integer", "default": 4 }, "period_type": { "type": "string", "enum": ["sprint", "week", "month"], "default": "sprint" }, "include_holidays": { "type": "boolean", "default": true } }, "required": ["team_id"] } },
    { "name": "retrospective_insights", "description": "Generate AI retrospective insights — what went well, improvements, and action items from sprint data", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" }, "sprint_id": { "type": "string" }, "include_metrics": { "type": "boolean", "default": true }, "anonymous_feedback": { "type": "array", "items": { "type": "string" } } }, "required": ["project_id"] } },
    { "name": "project_health_dashboard", "description": "Comprehensive project health report — schedule, budget, scope, quality, risk indicators", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" }, "indicators": { "type": "array", "items": { "type": "string", "enum": ["schedule", "budget", "scope", "quality", "risk", "all"] }, "default": ["all"] } }, "required": ["project_id"] } },
    { "name": "gantt_chart_data", "description": "Generate Gantt chart data with timelines, dependencies, milestones, and critical path", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" }, "include_dependencies": { "type": "boolean", "default": true }, "highlight_critical_path": { "type": "boolean", "default": true }, "group_by": { "type": "string", "enum": ["assignee", "phase", "priority"], "default": "phase" } }, "required": ["project_id"] } },
    { "name": "time_tracking_report", "description": "Time tracking report by team member, project, task, and billable breakdown", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "period_start": { "type": "string" }, "period_end": { "type": "string" }, "group_by": { "type": "string", "enum": ["member", "project", "task", "client"] }, "billable_only": { "type": "boolean", "default": false }, "project_id": { "type": "string" } }, "required": ["period_start", "period_end"] } },
    { "name": "scope_change_request", "description": "Submit or review a formal scope change request with impact analysis", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["submit", "review", "approve", "reject", "list_pending"] }, "project_id": { "type": "string" }, "change_request": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" }, "impact_schedule_days": { "type": "integer" }, "impact_budget": { "type": "number" }, "priority": { "type": "string" } } } }, "required": ["action", "project_id"] } },
    { "name": "standup_summary", "description": "Generate or collect daily standup summaries — yesterday, today, blockers", "category": "project-management", "required_role": "Employee", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["submit", "generate_from_activity", "get_team_summary"] }, "project_id": { "type": "string" }, "date": { "type": "string" }, "standup": { "type": "object", "properties": { "yesterday": { "type": "string" }, "today": { "type": "string" }, "blockers": { "type": "string" } } } }, "required": ["action"] } },
    { "name": "project_budget_tracking", "description": "Track project budget — actual vs planned, burn rate, and estimated cost at completion", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" }, "include_forecast": { "type": "boolean", "default": true }, "breakdown_by": { "type": "string", "enum": ["phase", "resource", "category", "month"] } }, "required": ["project_id"] } },
    { "name": "public_roadmap_gen", "description": "Generate a sanitized, public-facing product roadmap from internal task data for transparency with users and investors", "category": "project-management", "required_role": "Manager", "parameters": { "type": "object", "properties": { "project_id": { "type": "string" }, "timeframe": { "type": "string", "default": "quarters" } }, "required": ["project_id"] } }
  ]
}
