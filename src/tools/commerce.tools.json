{
  "category": "commerce",
  "description": "Comprehensive e-commerce operations — orders, products, inventory, pricing, logistics, customer intelligence, and marketplace analytics.",
  "tools": [
    { "name": "get_orders", "description": "Retrieve recent orders with filters for status, date range, customer, and fulfillment state", "category": "commerce", "required_role": "Employee", "parameters": { "type": "object", "properties": { "status": { "type": "string", "enum": ["open", "closed", "cancelled", "any"], "default": "any" }, "date_from": { "type": "string" }, "date_to": { "type": "string" }, "customer_email": { "type": "string" }, "fulfillment_status": { "type": "string", "enum": ["fulfilled", "unfulfilled", "partial", "any"] }, "limit": { "type": "integer", "default": 25 } }, "required": [] } },
    { "name": "get_product", "description": "Retrieve detailed product info including variants, metafields, inventory, and images", "category": "commerce", "required_role": "Employee", "parameters": { "type": "object", "properties": { "product_id": { "type": "string" } }, "required": ["product_id"] } },
    { "name": "create_order", "description": "Create a new order in the commerce platform", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "customer_email": { "type": "string" }, "line_items": { "type": "array", "items": { "type": "object", "properties": { "product_id": { "type": "string" }, "quantity": { "type": "integer" } } } }, "shipping_address": { "type": "object" }, "note": { "type": "string" }, "discount_code": { "type": "string" } }, "required": ["customer_email", "line_items"] } },
    { "name": "update_inventory", "description": "Update inventory quantity for a product or variant", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "product_id": { "type": "string" }, "variant_id": { "type": "string" }, "quantity": { "type": "integer" }, "adjustment": { "type": "integer" }, "location_id": { "type": "string" } }, "required": ["product_id"] } },
    { "name": "search_products", "description": "Search product catalog by name, SKU, category, or attributes", "category": "commerce", "required_role": "Employee", "parameters": { "type": "object", "properties": { "query": { "type": "string" }, "category": { "type": "string" }, "in_stock_only": { "type": "boolean", "default": false }, "price_min": { "type": "number" }, "price_max": { "type": "number" }, "limit": { "type": "integer", "default": 20 } }, "required": ["query"] } },
    { "name": "create_product", "description": "Create a new product with variants, pricing, images, and SEO metadata", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" }, "price": { "type": "number" }, "sku": { "type": "string" }, "category": { "type": "string" }, "tags": { "type": "array", "items": { "type": "string" } }, "variants": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "price": { "type": "number" }, "sku": { "type": "string" }, "inventory_quantity": { "type": "integer" } } } }, "weight": { "type": "number" }, "seo_title": { "type": "string" }, "seo_description": { "type": "string" } }, "required": ["title", "price"] } },
    { "name": "update_product", "description": "Update an existing product's details, pricing, or metadata", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "product_id": { "type": "string" }, "title": { "type": "string" }, "description": { "type": "string" }, "price": { "type": "number" }, "status": { "type": "string", "enum": ["active", "draft", "archived"] }, "tags": { "type": "array", "items": { "type": "string" } } }, "required": ["product_id"] } },
    { "name": "process_return", "description": "Process a product return or exchange — validate eligibility, generate return label, update inventory, and trigger refund", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "order_id": { "type": "string" }, "line_items": { "type": "array", "items": { "type": "object", "properties": { "product_id": { "type": "string" }, "quantity": { "type": "integer" }, "reason": { "type": "string", "enum": ["defective", "wrong_item", "not_as_described", "changed_mind", "other"] } } } }, "return_type": { "type": "string", "enum": ["refund", "exchange", "store_credit"] }, "restock": { "type": "boolean", "default": true } }, "required": ["order_id", "line_items", "return_type"] } },
    { "name": "create_discount", "description": "Create a discount code or automatic discount rule", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "code": { "type": "string" }, "type": { "type": "string", "enum": ["percentage", "fixed_amount", "free_shipping", "buy_x_get_y"] }, "value": { "type": "number" }, "min_purchase": { "type": "number" }, "max_uses": { "type": "integer" }, "start_date": { "type": "string" }, "end_date": { "type": "string" }, "applies_to": { "type": "string", "enum": ["all", "specific_products", "specific_collections"] }, "product_ids": { "type": "array", "items": { "type": "string" } } }, "required": ["type", "value"] } },
    { "name": "calculate_shipping", "description": "Calculate shipping rates for an order based on weight, dimensions, destination, and carrier", "category": "commerce", "required_role": "Employee", "parameters": { "type": "object", "properties": { "weight_kg": { "type": "number" }, "dimensions": { "type": "object", "properties": { "length_cm": { "type": "number" }, "width_cm": { "type": "number" }, "height_cm": { "type": "number" } } }, "origin_country": { "type": "string" }, "destination_country": { "type": "string" }, "destination_postal": { "type": "string" }, "carrier": { "type": "string", "enum": ["all", "dhl", "fedex", "ups", "aramex", "local"] } }, "required": ["weight_kg", "destination_country"] } },
    { "name": "fulfill_order", "description": "Mark an order as fulfilled with tracking information", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "order_id": { "type": "string" }, "tracking_number": { "type": "string" }, "carrier": { "type": "string" }, "line_items": { "type": "array", "items": { "type": "object", "properties": { "product_id": { "type": "string" }, "quantity": { "type": "integer" } } } }, "notify_customer": { "type": "boolean", "default": true } }, "required": ["order_id"] } },
    { "name": "cancel_order", "description": "Cancel an order and optionally process a refund and restock items", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "order_id": { "type": "string" }, "reason": { "type": "string" }, "refund": { "type": "boolean", "default": true }, "restock": { "type": "boolean", "default": true }, "notify_customer": { "type": "boolean", "default": true } }, "required": ["order_id"] } },
    { "name": "inventory_forecast", "description": "Forecast inventory needs based on historical sales velocity, lead times, and seasonality to prevent stockouts", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "product_ids": { "type": "array", "items": { "type": "string" }, "description": "Products to forecast (empty for all)" }, "forecast_days": { "type": "integer", "default": 30 }, "safety_stock_days": { "type": "integer", "default": 7 }, "lead_time_days": { "type": "integer", "default": 14 }, "include_seasonality": { "type": "boolean", "default": true } }, "required": [] } },
    { "name": "price_optimization", "description": "Analyze demand elasticity and competitor pricing to suggest optimal price points that maximize revenue or margin", "category": "commerce", "required_role": "Admin", "parameters": { "type": "object", "properties": { "product_id": { "type": "string" }, "optimization_goal": { "type": "string", "enum": ["maximize_revenue", "maximize_margin", "maximize_units", "competitive_match"] }, "competitor_prices": { "type": "array", "items": { "type": "object", "properties": { "competitor": { "type": "string" }, "price": { "type": "number" } } } }, "current_cost": { "type": "number" }, "min_margin_percent": { "type": "number" } }, "required": ["product_id", "optimization_goal"] } },
    { "name": "customer_segmentation", "description": "Segment customers by purchase behavior — RFM analysis (Recency, Frequency, Monetary), cohort grouping, and lifetime value tiers", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "method": { "type": "string", "enum": ["rfm", "cohort", "ltv_tier", "behavioral", "geographic"] }, "period_months": { "type": "integer", "default": 12 }, "num_segments": { "type": "integer", "default": 5 }, "include_recommendations": { "type": "boolean", "default": true } }, "required": ["method"] } },
    { "name": "abandoned_cart_recovery", "description": "Retrieve and take action on abandoned carts — list abandoned carts, trigger recovery emails, or apply incentive discounts", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["list", "send_reminder", "apply_discount"] }, "hours_abandoned": { "type": "integer", "default": 24 }, "discount_percent": { "type": "number", "description": "Discount to offer for recovery (only for apply_discount action)" }, "limit": { "type": "integer", "default": 50 } }, "required": ["action"] } },
    { "name": "sales_analytics", "description": "Generate detailed sales analytics — revenue trends, top products, conversion rates, average order value, and comparison periods", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "period_start": { "type": "string" }, "period_end": { "type": "string" }, "group_by": { "type": "string", "enum": ["day", "week", "month", "product", "category", "region", "channel"] }, "metrics": { "type": "array", "items": { "type": "string", "enum": ["revenue", "units_sold", "aov", "conversion_rate", "refund_rate", "top_products", "top_categories"] } }, "compare_previous": { "type": "boolean", "default": true } }, "required": ["period_start", "period_end"] } },
    { "name": "supplier_management", "description": "Manage supplier information, create purchase orders, and track supplier performance", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["list_suppliers", "get_supplier", "create_purchase_order", "track_shipment", "rate_supplier"] }, "supplier_id": { "type": "string" }, "purchase_order": { "type": "object", "properties": { "items": { "type": "array", "items": { "type": "object", "properties": { "product_id": { "type": "string" }, "quantity": { "type": "integer" }, "unit_cost": { "type": "number" } } } }, "expected_delivery": { "type": "string" } } } }, "required": ["action"] } },
    { "name": "product_recommendation", "description": "Generate product recommendations using collaborative filtering, content-based similarity, or frequently-bought-together analysis", "category": "commerce", "required_role": "Employee", "parameters": { "type": "object", "properties": { "method": { "type": "string", "enum": ["collaborative", "content_based", "frequently_bought_together", "trending", "personalized"] }, "product_id": { "type": "string", "description": "Base product for similarity (for content_based/frequently_bought_together)" }, "customer_id": { "type": "string", "description": "Customer for personalized recommendations" }, "limit": { "type": "integer", "default": 10 } }, "required": ["method"] } },
    { "name": "bulk_price_update", "description": "Apply bulk price changes across products by category, tag, or percentage/fixed adjustment", "category": "commerce", "required_role": "Admin", "parameters": { "type": "object", "properties": { "filter": { "type": "object", "properties": { "category": { "type": "string" }, "tag": { "type": "string" }, "product_ids": { "type": "array", "items": { "type": "string" } } } }, "adjustment_type": { "type": "string", "enum": ["percentage", "fixed_amount"] }, "adjustment_value": { "type": "number" }, "round_to": { "type": "number", "default": 0.99, "description": "Round prices to end in this value (e.g., 0.99)" }, "preview_only": { "type": "boolean", "default": true } }, "required": ["filter", "adjustment_type", "adjustment_value"] } },
    { "name": "customer_lifetime_value", "description": "Calculate Customer Lifetime Value (CLV) using historical purchase data, churn probability, and margin analysis", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "customer_id": { "type": "string", "description": "Specific customer (omit for aggregate analysis)" }, "model": { "type": "string", "enum": ["historical", "predictive", "cohort_based"], "default": "predictive" }, "discount_rate": { "type": "number", "default": 0.1 }, "time_horizon_years": { "type": "integer", "default": 3 } }, "required": [] } },
    { "name": "multi_location_inventory", "description": "View and transfer inventory across multiple warehouse or store locations", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["list_locations", "view_stock", "transfer", "reorder_suggestion"] }, "product_id": { "type": "string" }, "from_location": { "type": "string" }, "to_location": { "type": "string" }, "quantity": { "type": "integer" } }, "required": ["action"] } },
    { "name": "subscription_management", "description": "Manage SaaS or recurring physical product subscriptions — upgrades, downgrades, churn prevention, and dunning", "category": "commerce", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["list_subscriptions", "modify_plan", "pause", "cancel", "apply_discount", "dunning_status"] }, "subscription_id": { "type": "string" }, "customer_id": { "type": "string" }, "new_plan": { "type": "string" }, "pause_duration_days": { "type": "integer" } }, "required": ["action"] } }
  ]
}
