{
  "category": "legal",
  "description": "Legal operations — contract management, compliance tracking, IP protection, regulatory monitoring, e-signatures, and legal spend management.",
  "tools": [
    { "name": "contract_review", "description": "AI-powered contract review — extract key clauses, identify risks, flag unusual terms, and summarize obligations", "category": "legal", "required_role": "Manager", "parameters": { "type": "object", "properties": { "document_id": { "type": "string" }, "review_type": { "type": "string", "enum": ["full_review", "risk_assessment", "clause_extraction", "obligation_summary", "comparison"] }, "focus_areas": { "type": "array", "items": { "type": "string", "enum": ["liability", "termination", "payment_terms", "ip_rights", "confidentiality", "indemnification", "non_compete", "data_protection", "force_majeure"] } }, "compare_to_template": { "type": "string" } }, "required": ["document_id", "review_type"] } },
    { "name": "contract_generate", "description": "Generate a contract or legal document from a template with filled parameters", "category": "legal", "required_role": "Manager", "parameters": { "type": "object", "properties": { "template_type": { "type": "string", "enum": ["nda", "employment", "service_agreement", "sow", "msa", "saas_subscription", "partnership", "vendor", "freelancer", "lease"] }, "parties": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "role": { "type": "string" }, "address": { "type": "string" }, "representative": { "type": "string" } } } }, "terms": { "type": "object" }, "effective_date": { "type": "string" }, "expiry_date": { "type": "string" }, "jurisdiction": { "type": "string" }, "governing_law": { "type": "string" } }, "required": ["template_type", "parties"] } },
    { "name": "contract_lifecycle", "description": "Track contracts through their lifecycle — drafting, review, approval, execution, renewal, and expiry", "category": "legal", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["list_active", "expiring_soon", "pending_renewal", "get_status", "update_status", "get_obligations"] }, "contract_id": { "type": "string" }, "days_ahead": { "type": "integer", "default": 30 }, "status_filter": { "type": "string", "enum": ["draft", "in_review", "approved", "executed", "expiring", "expired", "terminated"] } }, "required": ["action"] } },
    { "name": "compliance_check", "description": "Check compliance status against regulatory frameworks — GDPR, SOC2, HIPAA, PCI-DSS, ISO 27001, local labor law", "category": "legal", "required_role": "Admin", "parameters": { "type": "object", "properties": { "framework": { "type": "string", "enum": ["gdpr", "soc2", "hipaa", "pci_dss", "iso_27001", "labor_law", "tax_compliance", "industry_specific"] }, "scope": { "type": "string", "enum": ["full_audit", "gap_analysis", "checklist", "specific_area"] }, "jurisdiction": { "type": "string" }, "specific_area": { "type": "string" } }, "required": ["framework"] } },
    { "name": "regulatory_monitor", "description": "Monitor regulatory changes and assess impact on the business — new laws, amendments, and compliance deadlines", "category": "legal", "required_role": "Admin", "parameters": { "type": "object", "properties": { "jurisdictions": { "type": "array", "items": { "type": "string" } }, "industries": { "type": "array", "items": { "type": "string" } }, "topics": { "type": "array", "items": { "type": "string", "enum": ["data_privacy", "employment", "taxation", "environmental", "financial", "trade", "ip", "consumer_protection"] } }, "lookback_days": { "type": "integer", "default": 30 } }, "required": ["jurisdictions"] } },
    { "name": "ip_portfolio", "description": "Manage intellectual property portfolio — patents, trademarks, copyrights, and trade secrets with renewal tracking", "category": "legal", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["list_assets", "add_asset", "renewal_calendar", "search_conflicts", "valuation"] }, "ip_type": { "type": "string", "enum": ["patent", "trademark", "copyright", "trade_secret", "domain"] }, "asset": { "type": "object", "properties": { "name": { "type": "string" }, "description": { "type": "string" }, "filing_date": { "type": "string" }, "expiry_date": { "type": "string" }, "jurisdiction": { "type": "string" }, "status": { "type": "string" } } } }, "required": ["action"] } },
    { "name": "legal_hold", "description": "Place or manage legal holds on documents and data for litigation or regulatory purposes", "category": "legal", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create", "release", "list_active", "add_custodians", "compliance_status"] }, "matter_name": { "type": "string" }, "custodians": { "type": "array", "items": { "type": "string" } }, "data_sources": { "type": "array", "items": { "type": "string" } }, "description": { "type": "string" } }, "required": ["action"] } },
    { "name": "policy_management", "description": "Create, distribute, and track acknowledgment of company policies", "category": "legal", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create_policy", "distribute", "track_acknowledgments", "list_policies", "update_policy"] }, "policy": { "type": "object", "properties": { "title": { "type": "string" }, "category": { "type": "string", "enum": ["hr", "it", "security", "privacy", "conduct", "financial", "safety"] }, "content": { "type": "string" }, "effective_date": { "type": "string" }, "review_date": { "type": "string" } } }, "target_audience": { "type": "string", "enum": ["all", "department", "role", "specific"] } }, "required": ["action"] } },
    { "name": "legal_spend_tracking", "description": "Track and analyze legal spending — outside counsel fees, matter costs, budget vs actual, and vendor comparison", "category": "legal", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["log_expense", "get_summary", "budget_vs_actual", "vendor_comparison", "forecast"] }, "matter_id": { "type": "string" }, "period": { "type": "string" }, "vendor": { "type": "string" }, "expense": { "type": "object", "properties": { "amount": { "type": "number" }, "category": { "type": "string" }, "vendor": { "type": "string" }, "description": { "type": "string" } } } }, "required": ["action"] } },
    { "name": "risk_register", "description": "Maintain a corporate risk register — legal, regulatory, operational, and reputational risks with mitigation tracking", "category": "legal", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["list_risks", "add_risk", "update_risk", "risk_matrix", "mitigation_status"] }, "risk": { "type": "object", "properties": { "title": { "type": "string" }, "category": { "type": "string", "enum": ["legal", "regulatory", "operational", "financial", "reputational", "cyber"] }, "likelihood": { "type": "string", "enum": ["rare", "unlikely", "possible", "likely", "certain"] }, "impact": { "type": "string", "enum": ["negligible", "minor", "moderate", "major", "catastrophic"] }, "mitigation": { "type": "string" }, "owner": { "type": "string" } } } }, "required": ["action"] } },
    { "name": "fast_agreement_gen", "description": "Generate Founder Advisor Standard Template (FAST) agreements and early-stage consulting contracts", "category": "legal", "required_role": "Manager", "parameters": { "type": "object", "properties": { "advisor_name": { "type": "string" }, "equity_percentage": { "type": "number" }, "vesting_period_months": { "type": "integer", "default": 24 } }, "required": ["advisor_name", "equity_percentage"] } }
  ]
}
