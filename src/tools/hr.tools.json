{
  "category": "hr",
  "description": "Comprehensive human resources — employee management, recruitment, payroll, performance, training, compliance, org design, and workforce analytics.",
  "tools": [
    { "name": "get_employee", "description": "Retrieve detailed employee information", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "employee_id": { "type": "string" }, "email": { "type": "string" } }, "required": [] } },
    { "name": "list_employees", "description": "List employees with filters for department, status, and role", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "department": { "type": "string" }, "status": { "type": "string", "enum": ["active", "inactive", "on_leave", "terminated"], "default": "active" }, "limit": { "type": "integer", "default": 50 } }, "required": [] } },
    { "name": "request_leave", "description": "Submit a leave/time-off request", "category": "hr", "required_role": "Employee", "parameters": { "type": "object", "properties": { "employee_id": { "type": "string" }, "leave_type": { "type": "string", "enum": ["annual", "sick", "personal", "maternity", "paternity", "unpaid", "bereavement", "study"] }, "start_date": { "type": "string" }, "end_date": { "type": "string" }, "reason": { "type": "string" }, "half_day": { "type": "boolean", "default": false } }, "required": ["employee_id", "leave_type", "start_date", "end_date"] } },
    { "name": "approve_leave", "description": "Approve or reject a pending leave request", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "request_id": { "type": "string" }, "decision": { "type": "string", "enum": ["approved", "rejected"] }, "comment": { "type": "string" } }, "required": ["request_id", "decision"] } },
    { "name": "get_payroll_summary", "description": "Retrieve payroll summary for an employee or the entire company for a period", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "employee_id": { "type": "string" }, "period": { "type": "string" }, "department": { "type": "string" } }, "required": [] } },
    { "name": "create_job_posting", "description": "Create a new job posting with requirements, compensation range, and publishing options", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "title": { "type": "string" }, "department": { "type": "string" }, "description": { "type": "string" }, "requirements": { "type": "array", "items": { "type": "string" } }, "nice_to_have": { "type": "array", "items": { "type": "string" } }, "employment_type": { "type": "string", "enum": ["full_time", "part_time", "contract", "internship", "freelance"] }, "location": { "type": "string" }, "remote": { "type": "string", "enum": ["onsite", "remote", "hybrid"] }, "salary_min": { "type": "number" }, "salary_max": { "type": "number" }, "currency": { "type": "string", "default": "EGP" }, "publish_to": { "type": "array", "items": { "type": "string", "enum": ["internal", "linkedin", "indeed", "company_website"] } } }, "required": ["title", "department", "description"] } },
    { "name": "recruitment_pipeline", "description": "Manage the recruitment pipeline — view candidates, move stages, schedule interviews, or reject", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["list_candidates", "move_stage", "schedule_interview", "reject", "make_offer", "get_pipeline_stats"] }, "job_id": { "type": "string" }, "candidate_id": { "type": "string" }, "stage": { "type": "string", "enum": ["applied", "screening", "phone_interview", "technical", "final_interview", "offer", "hired", "rejected"] }, "interview_details": { "type": "object", "properties": { "date": { "type": "string" }, "interviewer": { "type": "string" }, "type": { "type": "string", "enum": ["phone", "video", "onsite", "technical", "panel"] } } } }, "required": ["action"] } },
    { "name": "performance_review", "description": "Create, submit, or manage performance reviews with goals, ratings, and feedback", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create_cycle", "submit_review", "get_review", "list_pending", "aggregate_results"] }, "employee_id": { "type": "string" }, "review_cycle": { "type": "string" }, "review": { "type": "object", "properties": { "overall_rating": { "type": "number", "description": "1-5 scale" }, "goals_achieved": { "type": "array", "items": { "type": "object", "properties": { "goal": { "type": "string" }, "rating": { "type": "number" }, "comment": { "type": "string" } } } }, "strengths": { "type": "array", "items": { "type": "string" } }, "areas_for_improvement": { "type": "array", "items": { "type": "string" } }, "manager_comment": { "type": "string" } } } }, "required": ["action"] } },
    { "name": "set_employee_goals", "description": "Set or update OKRs/KPIs for an employee with tracking milestones", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "employee_id": { "type": "string" }, "period": { "type": "string" }, "goals": { "type": "array", "items": { "type": "object", "properties": { "objective": { "type": "string" }, "key_results": { "type": "array", "items": { "type": "string" } }, "weight": { "type": "number" }, "target_date": { "type": "string" } } } } }, "required": ["employee_id", "goals"] } },
    { "name": "skills_inventory", "description": "View, search, or update the company's skills inventory to find employees with specific competencies", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["search_by_skill", "get_employee_skills", "update_skills", "gap_analysis", "skills_matrix"] }, "skill_query": { "type": "string" }, "employee_id": { "type": "string" }, "department": { "type": "string" }, "proficiency_min": { "type": "string", "enum": ["beginner", "intermediate", "advanced", "expert"] } }, "required": ["action"] } },
    { "name": "training_management", "description": "Manage training programs — create courses, assign employees, track completion, and measure effectiveness", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create_course", "assign", "track_progress", "completion_report", "recommend_training"] }, "course": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" }, "type": { "type": "string", "enum": ["online", "instructor_led", "workshop", "certification"] }, "duration_hours": { "type": "number" }, "mandatory": { "type": "boolean" } } }, "employee_ids": { "type": "array", "items": { "type": "string" } } }, "required": ["action"] } },
    { "name": "org_chart", "description": "Generate or query the organizational chart — reporting lines, team structures, and span of control", "category": "hr", "required_role": "Employee", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["get_full", "get_department", "get_reports", "get_chain_of_command", "span_of_control_analysis"] }, "department": { "type": "string" }, "employee_id": { "type": "string" }, "depth": { "type": "integer", "default": 3 } }, "required": ["action"] } },
    { "name": "onboarding_workflow", "description": "Manage new hire onboarding — generate checklists, assign tasks, track completion, and schedule orientations", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create_checklist", "assign_buddy", "track_progress", "get_status", "schedule_orientation"] }, "employee_id": { "type": "string" }, "department": { "type": "string" }, "start_date": { "type": "string" }, "buddy_id": { "type": "string" } }, "required": ["action", "employee_id"] } },
    { "name": "offboarding_workflow", "description": "Manage employee offboarding — exit interviews, asset recovery, access revocation, and knowledge transfer", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["initiate", "schedule_exit_interview", "asset_checklist", "revoke_access", "get_status"] }, "employee_id": { "type": "string" }, "last_day": { "type": "string" }, "reason": { "type": "string", "enum": ["resignation", "termination", "retirement", "contract_end", "layoff"] }, "knowledge_transfer_to": { "type": "string" } }, "required": ["action", "employee_id"] } },
    { "name": "attendance_tracking", "description": "Track and report on employee attendance — clock in/out, absences, tardiness patterns, and overtime", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["clock_in", "clock_out", "get_report", "absence_summary", "overtime_report"] }, "employee_id": { "type": "string" }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "department": { "type": "string" } }, "required": ["action"] } },
    { "name": "compensation_benchmarking", "description": "Compare compensation against market rates by role, location, and experience level", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "role": { "type": "string" }, "location": { "type": "string" }, "experience_years": { "type": "integer" }, "industry": { "type": "string" }, "include_benefits": { "type": "boolean", "default": true }, "percentiles": { "type": "array", "items": { "type": "integer" }, "default": [25, 50, 75, 90] } }, "required": ["role", "location"] } },
    { "name": "employee_satisfaction_survey", "description": "Create, distribute, or analyze employee satisfaction/engagement surveys", "category": "hr", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create", "distribute", "get_results", "analyze_trends", "get_eNPS"] }, "survey": { "type": "object", "properties": { "title": { "type": "string" }, "questions": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" }, "type": { "type": "string", "enum": ["rating", "multiple_choice", "open_text", "nps"] } } } }, "anonymous": { "type": "boolean", "default": true } } }, "survey_id": { "type": "string" }, "department": { "type": "string" } }, "required": ["action"] } },
    { "name": "leave_balance", "description": "Check remaining leave balances for an employee across all leave types", "category": "hr", "required_role": "Employee", "parameters": { "type": "object", "properties": { "employee_id": { "type": "string" }, "year": { "type": "integer" } }, "required": ["employee_id"] } },
    { "name": "headcount_planning", "description": "Plan future headcount needs — open positions, hiring forecast, and budget impact analysis", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "department": { "type": "string" }, "forecast_quarters": { "type": "integer", "default": 4 }, "include_attrition": { "type": "boolean", "default": true }, "growth_scenario": { "type": "string", "enum": ["conservative", "moderate", "aggressive"] } }, "required": [] } },
    { "name": "diversity_report", "description": "Generate workforce diversity and inclusion metrics — gender, ethnicity, age distribution, pay equity analysis", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "report_type": { "type": "string", "enum": ["demographics", "pay_equity", "representation", "hiring_funnel", "retention", "comprehensive"] }, "department": { "type": "string" }, "period": { "type": "string" }, "benchmark_against": { "type": "string", "enum": ["industry", "company_avg", "previous_period"] } }, "required": ["report_type"] } },
    { "name": "workforce_analytics", "description": "Advanced workforce analytics — turnover rate, retention risk, absenteeism trends, cost per hire, and time to fill", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "metrics": { "type": "array", "items": { "type": "string", "enum": ["turnover_rate", "retention_risk", "absenteeism", "cost_per_hire", "time_to_fill", "employee_lifetime_value", "promotion_rate", "training_roi"] } }, "department": { "type": "string" }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "compare_previous": { "type": "boolean", "default": true } }, "required": ["metrics"] } },
    { "name": "compliance_tracker", "description": "Track regulatory compliance — certifications, mandatory training, visa expiry, work permits, and policy acknowledgments", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["expiring_soon", "missing_certifications", "training_compliance", "visa_tracker", "policy_acknowledgments"] }, "days_ahead": { "type": "integer", "default": 30 }, "department": { "type": "string" }, "employee_id": { "type": "string" } }, "required": ["action"] } },
    { "name": "benefits_administration", "description": "Manage employee benefits, open enrollment, health insurance, 401k/pension, and perks", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["view_enrollment", "update_benefits", "open_enrollment_status", "benefits_cost_analysis"] }, "employee_id": { "type": "string" }, "benefit_type": { "type": "string", "enum": ["health", "dental", "vision", "retirement", "life_insurance", "perks"] }, "plan_id": { "type": "string" } }, "required": ["action"] } },
    { "name": "equity_dilution_modeler", "description": "Model equity dilution for founders and early employees across multiple funding rounds and option pool expansions", "category": "hr", "required_role": "Admin", "parameters": { "type": "object", "properties": { "current_shares": { "type": "number" }, "new_investment_amount": { "type": "number" }, "pre_money_valuation": { "type": "number" }, "option_pool_increase": { "type": "number" } }, "required": ["current_shares", "new_investment_amount", "pre_money_valuation"] } }
  ]
}
