{
  "category": "storage",
  "description": "Enterprise file management — upload, download, search, share, versioning, OCR, digital signatures, backup, and storage analytics.",
  "tools": [
    { "name": "upload_file", "description": "Upload a file to cloud storage", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "file_name": { "type": "string" }, "folder_path": { "type": "string", "default": "/" }, "content_type": { "type": "string" }, "tags": { "type": "array", "items": { "type": "string" } } }, "required": ["file_name"] } },
    { "name": "download_file", "description": "Download or get a download link for a file", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "file_id": { "type": "string" }, "file_path": { "type": "string" } }, "required": [] } },
    { "name": "list_files", "description": "List files in a directory/folder", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "folder_path": { "type": "string", "default": "/" }, "limit": { "type": "integer", "default": 50 }, "sort_by": { "type": "string", "enum": ["name", "modified", "size", "type"], "default": "modified" } }, "required": [] } },
    { "name": "search_files", "description": "Full-text search across all stored files", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "query": { "type": "string" }, "file_type": { "type": "string" }, "modified_after": { "type": "string" }, "owner": { "type": "string" }, "limit": { "type": "integer", "default": 20 } }, "required": ["query"] } },
    { "name": "share_file", "description": "Share a file with specific users or generate a shareable link", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "file_id": { "type": "string" }, "share_with": { "type": "array", "items": { "type": "string" } }, "permission": { "type": "string", "enum": ["view", "edit", "comment"], "default": "view" }, "generate_link": { "type": "boolean", "default": false }, "link_expiry": { "type": "string" }, "password_protected": { "type": "boolean", "default": false } }, "required": ["file_id"] } },
    { "name": "create_folder", "description": "Create a new folder in the file system", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "folder_name": { "type": "string" }, "parent_path": { "type": "string", "default": "/" }, "description": { "type": "string" } }, "required": ["folder_name"] } },
    { "name": "move_file", "description": "Move or rename a file or folder", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "file_id": { "type": "string" }, "destination_path": { "type": "string" }, "new_name": { "type": "string" } }, "required": ["file_id", "destination_path"] } },
    { "name": "delete_file", "description": "Delete a file or move it to trash", "category": "storage", "required_role": "Manager", "parameters": { "type": "object", "properties": { "file_id": { "type": "string" }, "permanent": { "type": "boolean", "default": false } }, "required": ["file_id"] } },
    { "name": "version_history", "description": "View version history of a file and optionally restore a previous version", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "file_id": { "type": "string" }, "action": { "type": "string", "enum": ["list_versions", "restore_version", "compare_versions"] }, "version_id": { "type": "string" } }, "required": ["file_id"] } },
    { "name": "extract_text_ocr", "description": "Extract text from images, PDFs, or scanned documents using OCR", "category": "storage", "required_role": "Employee", "parameters": { "type": "object", "properties": { "file_id": { "type": "string" }, "language": { "type": "string", "default": "auto" }, "output_format": { "type": "string", "enum": ["plain_text", "structured", "searchable_pdf"], "default": "plain_text" } }, "required": ["file_id"] } },
    { "name": "request_signature", "description": "Request a digital/electronic signature on a document from one or more signers", "category": "storage", "required_role": "Manager", "parameters": { "type": "object", "properties": { "file_id": { "type": "string" }, "signers": { "type": "array", "items": { "type": "object", "properties": { "email": { "type": "string" }, "name": { "type": "string" }, "order": { "type": "integer" } } } }, "message": { "type": "string" }, "due_date": { "type": "string" }, "reminder": { "type": "boolean", "default": true } }, "required": ["file_id", "signers"] } },
    { "name": "bulk_operations", "description": "Perform bulk operations on files — move, copy, delete, tag, or permission changes", "category": "storage", "required_role": "Manager", "parameters": { "type": "object", "properties": { "operation": { "type": "string", "enum": ["move", "copy", "delete", "add_tag", "remove_tag", "change_permissions"] }, "file_ids": { "type": "array", "items": { "type": "string" } }, "destination": { "type": "string" }, "tag": { "type": "string" }, "permission": { "type": "object" } }, "required": ["operation", "file_ids"] } },
    { "name": "storage_analytics", "description": "Analyze storage usage — space by user/department, file type distribution, growth trends, and stale file detection", "category": "storage", "required_role": "Admin", "parameters": { "type": "object", "properties": { "report_type": { "type": "string", "enum": ["usage_by_user", "usage_by_department", "file_type_distribution", "growth_trend", "stale_files", "largest_files", "sharing_audit"] }, "department": { "type": "string" }, "older_than_days": { "type": "integer", "default": 180 }, "limit": { "type": "integer", "default": 50 } }, "required": ["report_type"] } },
    { "name": "access_audit_log", "description": "View file access audit logs — who viewed, edited, shared, or downloaded specific files", "category": "storage", "required_role": "Admin", "parameters": { "type": "object", "properties": { "file_id": { "type": "string" }, "user_id": { "type": "string" }, "action_type": { "type": "string", "enum": ["view", "edit", "share", "download", "delete", "all"] }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "limit": { "type": "integer", "default": 100 } }, "required": [] } },
    { "name": "create_document_template", "description": "Create a reusable document template with fillable fields for contracts, proposals, or reports", "category": "storage", "required_role": "Manager", "parameters": { "type": "object", "properties": { "name": { "type": "string" }, "base_file_id": { "type": "string" }, "fields": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "string", "enum": ["text", "date", "number", "signature", "checkbox"] }, "required": { "type": "boolean" } } } }, "category": { "type": "string", "enum": ["contract", "proposal", "report", "invoice", "letter", "other"] } }, "required": ["name", "fields"] } }
  ]
}
