{
  "category": "communications",
  "description": "Full-spectrum communications — email, messaging, scheduling, templates, campaigns, translation, calendar management, and notification orchestration.",
  "tools": [
    { "name": "send_email", "description": "Compose and send an email to one or more recipients", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "to": { "type": "array", "items": { "type": "string" } }, "subject": { "type": "string" }, "body": { "type": "string" }, "cc": { "type": "array", "items": { "type": "string" } }, "bcc": { "type": "array", "items": { "type": "string" } }, "attachments": { "type": "array", "items": { "type": "string" } }, "priority": { "type": "string", "enum": ["low", "normal", "high"] }, "reply_to": { "type": "string" } }, "required": ["to", "subject", "body"] } },
    { "name": "read_inbox", "description": "Retrieve recent emails from inbox with optional filters", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "limit": { "type": "integer", "default": 10 }, "unread_only": { "type": "boolean", "default": false }, "from_filter": { "type": "string" }, "folder": { "type": "string", "default": "inbox" } }, "required": [] } },
    { "name": "search_emails", "description": "Search emails by keyword, sender, date range, or labels", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "query": { "type": "string" }, "date_from": { "type": "string" }, "date_to": { "type": "string" }, "has_attachment": { "type": "boolean" }, "limit": { "type": "integer", "default": 20 } }, "required": ["query"] } },
    { "name": "send_message", "description": "Send a message to a channel, group, or direct conversation", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "channel": { "type": "string" }, "message": { "type": "string" }, "thread_id": { "type": "string" }, "mentions": { "type": "array", "items": { "type": "string" } } }, "required": ["channel", "message"] } },
    { "name": "list_channels", "description": "List all available communication channels or groups", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "type": { "type": "string", "enum": ["all", "direct", "group", "channel"], "default": "all" } }, "required": [] } },
    { "name": "schedule_email", "description": "Schedule an email to be sent at a specific future date/time", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "to": { "type": "array", "items": { "type": "string" } }, "subject": { "type": "string" }, "body": { "type": "string" }, "send_at": { "type": "string", "description": "ISO 8601 datetime for scheduled send" }, "timezone": { "type": "string", "default": "Africa/Cairo" } }, "required": ["to", "subject", "body", "send_at"] } },
    { "name": "create_email_template", "description": "Create a reusable email template with variable placeholders", "category": "communications", "required_role": "Manager", "parameters": { "type": "object", "properties": { "name": { "type": "string" }, "subject_template": { "type": "string" }, "body_template": { "type": "string", "description": "Use {{variable_name}} for placeholders" }, "category": { "type": "string", "enum": ["sales", "support", "onboarding", "marketing", "internal", "legal"] }, "variables": { "type": "array", "items": { "type": "string" }, "description": "List of variable names used in the template" } }, "required": ["name", "subject_template", "body_template"] } },
    { "name": "send_bulk_email", "description": "Send a personalized email to a list of recipients using a template", "category": "communications", "required_role": "Manager", "parameters": { "type": "object", "properties": { "template_id": { "type": "string" }, "recipients": { "type": "array", "items": { "type": "object", "properties": { "email": { "type": "string" }, "variables": { "type": "object" } } } }, "send_at": { "type": "string" }, "throttle_per_hour": { "type": "integer", "default": 200 } }, "required": ["template_id", "recipients"] } },
    { "name": "create_calendar_event", "description": "Create a calendar event or meeting invitation", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "title": { "type": "string" }, "start_time": { "type": "string" }, "end_time": { "type": "string" }, "attendees": { "type": "array", "items": { "type": "string" } }, "location": { "type": "string" }, "description": { "type": "string" }, "recurrence": { "type": "string", "enum": ["none", "daily", "weekly", "biweekly", "monthly"] }, "video_conference": { "type": "boolean", "default": false }, "timezone": { "type": "string", "default": "Africa/Cairo" } }, "required": ["title", "start_time", "end_time"] } },
    { "name": "check_availability", "description": "Check calendar availability for one or more people to find meeting slots", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "attendees": { "type": "array", "items": { "type": "string" } }, "date_range_start": { "type": "string" }, "date_range_end": { "type": "string" }, "duration_minutes": { "type": "integer", "default": 30 }, "working_hours_only": { "type": "boolean", "default": true }, "timezone": { "type": "string", "default": "Africa/Cairo" } }, "required": ["attendees", "date_range_start", "date_range_end"] } },
    { "name": "translate_message", "description": "Translate text between languages for cross-team or international communication", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "text": { "type": "string" }, "source_language": { "type": "string", "default": "auto" }, "target_language": { "type": "string" }, "formality": { "type": "string", "enum": ["formal", "informal", "auto"], "default": "auto" } }, "required": ["text", "target_language"] } },
    { "name": "summarize_thread", "description": "Generate an AI summary of a long email thread or chat conversation", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "thread_id": { "type": "string" }, "source": { "type": "string", "enum": ["email", "slack", "teams", "chat"] }, "include_action_items": { "type": "boolean", "default": true }, "max_length": { "type": "string", "enum": ["brief", "detailed"], "default": "brief" } }, "required": ["thread_id", "source"] } },
    { "name": "set_auto_responder", "description": "Configure an automatic reply (out-of-office, vacation, or custom auto-response)", "category": "communications", "required_role": "Employee", "parameters": { "type": "object", "properties": { "enabled": { "type": "boolean" }, "subject": { "type": "string" }, "body": { "type": "string" }, "start_date": { "type": "string" }, "end_date": { "type": "string" }, "reply_to_external": { "type": "boolean", "default": true }, "reply_to_internal": { "type": "boolean", "default": true } }, "required": ["enabled"] } },
    { "name": "create_contact_group", "description": "Create or manage a distribution list / contact group for bulk communications", "category": "communications", "required_role": "Manager", "parameters": { "type": "object", "properties": { "action": { "type": "string", "enum": ["create", "add_members", "remove_members", "list", "delete"] }, "group_name": { "type": "string" }, "members": { "type": "array", "items": { "type": "string" } } }, "required": ["action"] } },
    { "name": "send_notification", "description": "Send a push notification, SMS, or in-app notification to users", "category": "communications", "required_role": "Manager", "parameters": { "type": "object", "properties": { "channel": { "type": "string", "enum": ["push", "sms", "in_app", "email", "all"] }, "recipients": { "type": "array", "items": { "type": "string" } }, "title": { "type": "string" }, "body": { "type": "string" }, "priority": { "type": "string", "enum": ["low", "normal", "high", "critical"] }, "action_url": { "type": "string" } }, "required": ["channel", "recipients", "title", "body"] } },
    { "name": "communication_analytics", "description": "Analyze communication patterns — response times, message volume, peak hours, and team engagement metrics", "category": "communications", "required_role": "Manager", "parameters": { "type": "object", "properties": { "period_start": { "type": "string" }, "period_end": { "type": "string" }, "metrics": { "type": "array", "items": { "type": "string", "enum": ["avg_response_time", "message_volume", "peak_hours", "top_senders", "unread_rate", "thread_resolution_time"] } }, "group_by": { "type": "string", "enum": ["user", "team", "channel", "day"] } }, "required": ["period_start", "period_end"] } },
    { "name": "internal_announcement", "description": "Broadcast a company-wide or department-wide internal announcement across multiple channels (email, Slack, intranet)", "category": "communications", "required_role": "Manager", "parameters": { "type": "object", "properties": { "title": { "type": "string" }, "body": { "type": "string" }, "audience": { "type": "string", "enum": ["all_hands", "department", "executives", "custom_group"] }, "target_group": { "type": "string" }, "channels": { "type": "array", "items": { "type": "string", "enum": ["email", "slack", "teams", "intranet"] }, "default": ["email"] }, "priority": { "type": "string", "enum": ["standard", "urgent", "critical"] }, "send_at": { "type": "string" } }, "required": ["title", "body", "audience", "channels"] } }
  ]
}
