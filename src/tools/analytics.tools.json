{
  "category": "analytics",
  "description": "Business intelligence — KPI dashboards, custom reports, data visualization, cohort analysis, trend detection, anomaly alerts, and predictive modeling.",
  "tools": [
    { "name": "kpi_dashboard", "description": "Generate a real-time KPI dashboard with key business metrics across departments", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "dashboard_type": { "type": "string", "enum": ["executive", "sales", "marketing", "operations", "finance", "hr", "custom"] }, "period": { "type": "string" }, "compare_period": { "type": "string", "enum": ["previous_period", "previous_year", "none"], "default": "previous_period" }, "kpis": { "type": "array", "items": { "type": "string" } } }, "required": ["dashboard_type"] } },
    { "name": "custom_report", "description": "Build a custom report by selecting data sources, metrics, dimensions, and filters", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "title": { "type": "string" }, "data_sources": { "type": "array", "items": { "type": "string", "enum": ["sales", "finance", "hr", "crm", "commerce", "support", "marketing"] } }, "metrics": { "type": "array", "items": { "type": "string" } }, "dimensions": { "type": "array", "items": { "type": "string" } }, "filters": { "type": "object" }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "group_by": { "type": "string" }, "sort_by": { "type": "string" }, "output_format": { "type": "string", "enum": ["table", "chart", "summary", "csv"], "default": "table" } }, "required": ["title", "data_sources", "metrics"] } },
    { "name": "cohort_analysis", "description": "Perform cohort analysis — group users/customers by acquisition date or behavior and track retention, revenue, or engagement over time", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "cohort_type": { "type": "string", "enum": ["acquisition", "behavioral", "value_based"] }, "metric": { "type": "string", "enum": ["retention", "revenue", "orders", "engagement", "churn"] }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "granularity": { "type": "string", "enum": ["daily", "weekly", "monthly"], "default": "monthly" } }, "required": ["cohort_type", "metric"] } },
    { "name": "trend_analysis", "description": "Detect and analyze trends in business data — identify inflection points, seasonal patterns, and growth/decline rates", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "metric": { "type": "string" }, "data_source": { "type": "string" }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "granularity": { "type": "string", "enum": ["daily", "weekly", "monthly"], "default": "weekly" }, "include_forecast": { "type": "boolean", "default": true }, "forecast_periods": { "type": "integer", "default": 6 } }, "required": ["metric", "data_source"] } },
    { "name": "anomaly_detection", "description": "Automatically detect anomalies in business metrics — unusual spikes, drops, or pattern deviations that require attention", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "metrics": { "type": "array", "items": { "type": "string" } }, "sensitivity": { "type": "string", "enum": ["low", "medium", "high"], "default": "medium" }, "lookback_days": { "type": "integer", "default": 30 }, "alert_threshold_sigma": { "type": "number", "default": 2.0 } }, "required": ["metrics"] } },
    { "name": "funnel_analysis", "description": "Analyze conversion funnels — drop-off rates at each stage, bottleneck identification, and optimization suggestions", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "funnel_type": { "type": "string", "enum": ["sales", "marketing", "onboarding", "support", "custom"] }, "stages": { "type": "array", "items": { "type": "string" } }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "segment_by": { "type": "string" } }, "required": ["funnel_type"] } },
    { "name": "predictive_model", "description": "Build or query a predictive model for business outcomes — demand forecasting, customer behavior prediction, or resource needs", "category": "analytics", "required_role": "Admin", "parameters": { "type": "object", "properties": { "model_type": { "type": "string", "enum": ["demand_forecast", "churn_prediction", "lead_conversion", "revenue_prediction", "resource_demand", "price_elasticity"] }, "features": { "type": "array", "items": { "type": "string" } }, "target_variable": { "type": "string" }, "training_period": { "type": "string" }, "prediction_horizon": { "type": "integer" } }, "required": ["model_type"] } },
    { "name": "ab_test_analysis", "description": "Analyze A/B test results — statistical significance, effect size, confidence intervals, and recommendation", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "test_name": { "type": "string" }, "control_group": { "type": "object", "properties": { "visitors": { "type": "integer" }, "conversions": { "type": "integer" }, "revenue": { "type": "number" } } }, "variant_groups": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "visitors": { "type": "integer" }, "conversions": { "type": "integer" }, "revenue": { "type": "number" } } } }, "confidence_level": { "type": "number", "default": 0.95 }, "primary_metric": { "type": "string", "enum": ["conversion_rate", "revenue_per_visitor", "average_order_value"] } }, "required": ["test_name", "control_group", "variant_groups"] } },
    { "name": "data_export", "description": "Export business data in various formats for external analysis or reporting", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "data_source": { "type": "string", "enum": ["orders", "customers", "transactions", "employees", "tasks", "communications", "all"] }, "format": { "type": "string", "enum": ["csv", "json", "xlsx", "pdf"] }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "columns": { "type": "array", "items": { "type": "string" } }, "filters": { "type": "object" } }, "required": ["data_source", "format"] } },
    { "name": "benchmark_comparison", "description": "Compare your company's metrics against industry benchmarks or previous periods", "category": "analytics", "required_role": "Manager", "parameters": { "type": "object", "properties": { "metrics": { "type": "array", "items": { "type": "string" } }, "industry": { "type": "string" }, "company_size": { "type": "string", "enum": ["startup", "smb", "mid_market", "enterprise"] }, "period": { "type": "string" } }, "required": ["metrics"] } },
    { "name": "correlation_analysis", "description": "Discover correlations between business variables — find which factors most influence revenue, churn, satisfaction, or productivity", "category": "analytics", "required_role": "Admin", "parameters": { "type": "object", "properties": { "variables": { "type": "array", "items": { "type": "string" }, "description": "Variables to analyze (e.g., ['marketing_spend', 'revenue', 'customer_satisfaction'])" }, "period_start": { "type": "string" }, "period_end": { "type": "string" }, "method": { "type": "string", "enum": ["pearson", "spearman", "mutual_information"], "default": "pearson" } }, "required": ["variables"] } },
    { "name": "executive_summary", "description": "Generate an AI-powered executive summary of business performance covering all departments and key metrics", "category": "analytics", "required_role": "Admin", "parameters": { "type": "object", "properties": { "period": { "type": "string" }, "focus_areas": { "type": "array", "items": { "type": "string", "enum": ["revenue", "costs", "growth", "efficiency", "customer", "team", "risks"] } }, "tone": { "type": "string", "enum": ["formal", "concise", "detailed"], "default": "concise" }, "include_recommendations": { "type": "boolean", "default": true } }, "required": ["period"] } }
  ]
}
